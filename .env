# =============================================================================
# IFC-Agent LLM Configuration  (active runtime values)
# =============================================================================
# Switch model by editing LLM_PROVIDER below.  Three first-class providers:
#   deepseek  →  DeepSeek V4 series       (block A)
#   openai    →  ChatGPT / GPT family     (block B)
#   claude    →  Anthropic Claude         (block C)
#
# CLI flags --provider / --model override these values.
# =============================================================================

# ---- Active provider ----
# Options: deepseek | openai | claude
LLM_PROVIDER=deepseek


# ============================================================================
# (A)  DeepSeek V4 series   —  https://platform.deepseek.com
# ----------------------------------------------------------------------------
# Models: deepseek-v4-pro (recommended, thinking-on by default)
#         deepseek-chat   (V4 general)
#         deepseek-reasoner (R1 reasoning)
#
# Thinking mode (docs: https://api-docs.deepseek.com/zh-cn/guides/thinking_mode)
#   DEEPSEEK_THINKING            — true (default) | false
#   DEEPSEEK_REASONING_EFFORT    — high (default) | max
# In thinking mode, temperature / top_p / presence_penalty / frequency_penalty
# are silently ignored and auto-stripped by LLMBackend.
# ============================================================================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING=true
DEEPSEEK_REASONING_EFFORT=high


# ============================================================================
# (B)  OpenAI / ChatGPT     —  https://platform.openai.com
# ----------------------------------------------------------------------------
# Models: gpt-4o | gpt-4o-mini | o3-mini | o4-mini
#
# NOTE: The active values below currently point at MiniMax's OpenAI-
# compatible endpoint, because that is the upstream key we have on hand.
# To use the real OpenAI ChatGPT, replace with:
#   OPENAI_API_KEY=sk-...                          (your OpenAI key)
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o
# ============================================================================
OPENAI_API_KEY=''
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_MODEL=MiniMax-M2.7-highspeed


# ============================================================================
# (C)  Anthropic Claude     —  https://console.anthropic.com
# ----------------------------------------------------------------------------
# Models:
#   claude-sonnet-4-20250514    (balanced, recommended)
#   claude-opus-4-20250514      (strongest)
#   claude-sonnet-4-5-20250929  (newest Sonnet 4.5)
# Leave CLAUDE_BASE_URL empty for the official Anthropic endpoint.
# ============================================================================
CLAUDE_API_KEY=sk-ant-your-anthropic-api-key
CLAUDE_BASE_URL=
CLAUDE_MODEL=claude-sonnet-4-20250514


# ============================================================================
# (D)  Google Gemini / Vertex AI   (optional, legacy)
# ============================================================================
GEMINI_API_KEY=your-gemini-api-key
VERTEX_PROJECT=
VERTEX_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
