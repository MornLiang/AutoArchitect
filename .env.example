# =============================================================================
# IFC-Agent LLM Configuration
# =============================================================================
# Usage:
#   1. cp .env.example .env
#   2. Set LLM_PROVIDER to ONE of: deepseek | openai | claude
#   3. Fill in the API key (and base URL / model if you need to override)
#      in the matching section below.
#   4. Run:
#        python run_text2ifc.py --gt ../demo_data/"1px(1).ifc"
#        python main.py --ifc ../demo_data/"1px(1).ifc" --query "..."
#
# CLI flags --provider / --model override the values in this file.
# =============================================================================

# ---- Step 1: Choose your provider ----
# Supported: deepseek | openai | claude | gemini
# (gemini is kept for backwards compatibility; primary supported set is the
#  first three.)
LLM_PROVIDER=deepseek


# ============================================================================
# (A)  DeepSeek V4 series  (https://platform.deepseek.com)
# ----------------------------------------------------------------------------
# Models (canonical lower-case names per DeepSeek API docs):
#   deepseek-v4-pro     — V4 Pro, thinking-enabled by default (recommended)
#   deepseek-chat       — V4 general chat
#   deepseek-reasoner   — R1 reasoning model
# Endpoint:
#   https://api.deepseek.com         (OpenAI-wire-compatible)
#
# Thinking mode (chain-of-thought):
#   docs: https://api-docs.deepseek.com/zh-cn/guides/thinking_mode
#   • DEEPSEEK_THINKING            — true (default) | false
#   • DEEPSEEK_REASONING_EFFORT    — high (default) | max
#       (low / medium → auto-promoted to high; xhigh → max)
#   In thinking mode, temperature / top_p / presence_penalty /
#   frequency_penalty are IGNORED by the API and stripped by the backend.
# ============================================================================
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING=true
DEEPSEEK_REASONING_EFFORT=high


# ============================================================================
# (B)  OpenAI / ChatGPT  (https://platform.openai.com)
# ----------------------------------------------------------------------------
# Models:
#   gpt-4o              — flagship multimodal
#   gpt-4o-mini         — fast & cheap general model
#   o3-mini, o4-mini    — reasoning models (use reasoning_effort)
# Endpoint:
#   https://api.openai.com/v1
#
# This block also covers ANY OpenAI-compatible API (MiniMax, GLM, Qwen, …) —
# just override OPENAI_BASE_URL + OPENAI_MODEL accordingly.
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o


# ============================================================================
# (C)  Anthropic Claude  (https://console.anthropic.com)
# ----------------------------------------------------------------------------
# Models:
#   claude-sonnet-4-20250514    — balanced (recommended default)
#   claude-opus-4-20250514      — strongest reasoning
#   claude-sonnet-4-5-20250929  — newest Sonnet 4.5
# Endpoint:
#   (leave CLAUDE_BASE_URL empty for the official Anthropic endpoint)
# ============================================================================
CLAUDE_API_KEY=sk-ant-your-anthropic-api-key
CLAUDE_BASE_URL=
CLAUDE_MODEL=claude-sonnet-4-20250514


# ============================================================================
# (D)  Google Gemini / Vertex AI   (optional, legacy)
# ============================================================================
GEMINI_API_KEY=your-gemini-api-key
VERTEX_PROJECT=
VERTEX_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
